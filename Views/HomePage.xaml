<UserControl x:Class="AnimeDiscover.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnimeDiscover.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Title Section-->
        <TextBlock Grid.Row="0" Text="🎌 Animes de la Saison" FontSize="24" FontWeight="Bold" 
                   Foreground="{DynamicResource TextPrimaryColor}" Margin="30,20,0,15"/>

        <!--Anime Grid List-->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="AnimeItemsControl" ItemsSource="{Binding Animes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Margin="20"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!--Anime Card-->
                        <Border Width="200" Height="320" Margin="10" 
                                Background="{DynamicResource SurfaceBrush}" CornerRadius="10" 
                                BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1"
                                Cursor="Hand" MouseLeftButtonDown="AnimeCard_MouseLeftButtonDown"
                                Tag="{Binding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="220"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!--Anime Cover Image-->
                                <Border Grid.Row="0" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8,8,0,0" ClipToBounds="True">
                                    <Image Source="{Binding ImageUrl}" 
                                           Stretch="UniformToFill" 
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                </Border>

                                <!--Anime Info Section-->
                                <StackPanel Grid.Row="1" Margin="12" VerticalAlignment="Top">
                                    <!--Title-->
                                    <TextBlock Text="{Binding Title}" 
                                               FontSize="13" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextPrimaryColor}" 
                                               TextWrapping="Wrap"
                                               MaxHeight="50"
                                               LineHeight="16"/>

                                    <!--Type and Year-->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Type}" 
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" FontWeight="SemiBold"/>
                                        <TextBlock Text=" • " FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="4,0"/>
                                        <TextBlock Text="{Binding Year}" 
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryColor}"/>
                                    </StackPanel>

                                    <!--Score-->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="⭐" FontSize="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Score, StringFormat='0.0'}" 
                                                   FontSize="11" Foreground="#FF9800" FontWeight="Bold"/>
                                    </StackPanel>

                                    <!--Genres-->
                                    <ItemsControl ItemsSource="{Binding Genres}" Margin="0,8,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E3F2FD" CornerRadius="4" Padding="5,2" Margin="0,2,4,2">
                                                    <TextBlock Text="{Binding}" 
                                                               FontSize="10" Foreground="#1976D2" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
