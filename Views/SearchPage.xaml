<Page x:Class="AnimeDiscover.Views.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AnimeDiscover.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SearchPage"
      Background="#001A2B">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Haut de page -->
        <TextBlock Grid.Row="0" 
            Text="Résultats" 
            Foreground="{DynamicResource TextSecondaryColor}"
            FontSize="16"
            FontWeight="SemiBold"
            Margin="5,0,0,15"/>

            <!-- Grille d'animes -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl Name="AnimeList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AnimeCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Nom et Description -->
                                <StackPanel Grid.Column="0" 
                                        VerticalAlignment="Center"
                                        Margin="0,0,15,0">
                                    <TextBlock Text="{Binding AnimeName}" 
                                           Foreground="{DynamicResource TextPrimaryColor}"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Description}" 
                                           Foreground="{DynamicResource TextSecondaryColor}"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Image et Note -->
                                <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <Viewbox Height="35" Width="35" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding AnimeJPG}" 
                                               FontSize="35"
                                               Foreground="{DynamicResource TextPrimaryColor}"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding Note}" 
                                           Foreground="{DynamicResource TextSecondaryColor}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="100"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
