<UserControl x:Class="AnimeDiscover.Views.AnimePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnimeDiscover.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <!-- Page de détail d'un anime -->
    <Grid>
        <Grid.Resources>
            <Style x:Key="StarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#FFC107"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
                <Setter Property="Padding" Value="2,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#140E3D" Offset="0.0"/>
                <GradientStop Color="#8378C7" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Back Button-->
        <Button Grid.Row="0" Content="{DynamicResource AnimePage.Back}" Padding="10,8" Background="#2196F3" 
                Foreground="White" Cursor="Hand" Margin="20,10,0,10" Width="100" 
                HorizontalAlignment="Left" Click="BackButton_Click"/>

        <!--Content-->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <!--Title and Basic Info-->
                <TextBlock Text="{Binding CurrentAnime.Title}" FontSize="28" FontWeight="Bold" 
                           Foreground="White" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="{Binding CurrentAnime.Type}" FontSize="14" Foreground="White"/>
                    <TextBlock Text=" | " FontSize="14" Foreground="White" Margin="10,0"/>
                    <TextBlock Text="{Binding CurrentAnime.Year}" FontSize="14" Foreground="White"/>
                    <TextBlock Text=" | " FontSize="14" Foreground="White" Margin="10,0"/>
                    <TextBlock Text="{Binding CurrentAnime.Episodes}" FontSize="14" Foreground="White"/>
                    <TextBlock Text=" eps" FontSize="14" Foreground="White"/>
                    <TextBlock Text=" | " FontSize="14" Foreground="White" Margin="10,0"/>
                    <TextBlock Text="{Binding CurrentAnime.Score, StringFormat='⭐ 0.0'}" 
                               FontSize="14" Foreground="#FF9800"/>
                </StackPanel>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--Anime Cover Image-->
                    <Border Grid.Column="0" Background="#E0E0E0" CornerRadius="8" ClipToBounds="True">
                        <Image Source="{Binding CurrentAnime.ImageUrl}" 
                               Stretch="UniformToFill" Height="350" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!--User Interactions and Info-->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="{DynamicResource AnimePage.UserInfo}" FontSize="14" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,10"/>

                        <!--Watched Checkbox-->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <CheckBox x:Name="WatchedCheckBox" IsChecked="{Binding CurrentAnime.IsWatched}" 
                                      VerticalAlignment="Center" Width="20" Height="20" Checked="WatchedCheckBox_Checked" Unchecked="WatchedCheckBox_Checked"/>
                            <TextBlock Text="{DynamicResource AnimePage.Watched}" FontSize="12" Foreground="White" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!--User Score Slider-->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="{DynamicResource AnimePage.MyScore}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <StackPanel x:Name="AnimePageStarsPanel" Orientation="Horizontal" Loaded="StarRatingPanel_Loaded" MouseLeave="StarRatingPanel_MouseLeave">
                                <Button Style="{StaticResource StarButtonStyle}" Content="☆" Tag="1" Click="StarButton_Click" MouseEnter="StarButton_MouseEnter" />
                                <Button Style="{StaticResource StarButtonStyle}" Content="☆" Tag="2" Click="StarButton_Click" MouseEnter="StarButton_MouseEnter"/>
                                <Button Style="{StaticResource StarButtonStyle}" Content="☆" Tag="3" Click="StarButton_Click" MouseEnter="StarButton_MouseEnter"/>
                                <Button Style="{StaticResource StarButtonStyle}" Content="☆" Tag="4" Click="StarButton_Click" MouseEnter="StarButton_MouseEnter"/>
                                <Button Style="{StaticResource StarButtonStyle}" Content="☆" Tag="5" Click="StarButton_Click" MouseEnter="StarButton_MouseEnter"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="{DynamicResource AnimePage.EpisodesWatched}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <TextBox Width="120"
                                     HorizontalAlignment="Left"
                                     Margin="0,2,0,0"
                                     Text="{Binding CurrentAnime.EpisodesWatched, UpdateSourceTrigger=Explicit}"
                                     ToolTip="{DynamicResource AnimePage.EpisodesWatchedTip}"
                                     KeyDown="EpisodesWatchedTextBox_KeyDown"
                                     LostFocus="EpisodesWatchedTextBox_LostFocus" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <!--Statut-->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource AnimePage.Status}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentAnime.Status}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!--Saison et Source-->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource AnimePage.Season}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentAnime.Season}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource AnimePage.Source}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CurrentAnime.Source}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!--Classement-->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource AnimePage.RankPopularity}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentAnime.Rank, StringFormat='Rank: #{0}'}" FontSize="11" Foreground="White"/>
                                <TextBlock Text=" | " FontSize="11" Foreground="White" Margin="5,0"/>
                                <TextBlock Text="{Binding CurrentAnime.Popularity, StringFormat='Pop: #{0}'}" FontSize="11" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>

                        <!--Score MAL-->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource AnimePage.MalScore}" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentAnime.Score, StringFormat='⭐ {0:F1}'}" FontSize="11" Foreground="#FF9800" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentAnime.ScoredBy, StringFormat=' ({0:N0} votes)'}" FontSize="11" Foreground="White" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!--Genres and Themes-->
                <Grid Margin="0,20,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="{DynamicResource AnimePage.Genres}" FontSize="14" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="GenresItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#E3F2FD" CornerRadius="4" Padding="8,4" Margin="0,2,8,2">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#1976D2" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource AnimePage.Themes}" FontSize="14" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding CurrentAnime.Themes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF3E0" CornerRadius="4" Padding="8,4" Margin="0,2,8,2">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#F57C00" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!--Studios and Producers-->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="{DynamicResource AnimePage.Studios}" FontSize="14" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding CurrentAnime.Studios}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F3E5F5" CornerRadius="4" Padding="8,4" Margin="0,2,8,2">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#7B1FA2" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource AnimePage.Producers}" FontSize="14" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding CurrentAnime.Producers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8,4" Margin="0,2,8,2">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#2E7D32" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!--Synopsis-->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{DynamicResource AnimePage.Synopsis}" FontSize="14" FontWeight="Bold" 
                               Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock x:Name="SynopsisTextBlock" Text="{Binding CurrentAnime.Synopsis}" FontSize="12" 
                               Foreground="White" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>

                <!--Background (si disponible)-->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{Binding CurrentAnime.Background, StringFormat='Background: {0}'}" FontSize="12" 
                               Foreground="White" TextWrapping="Wrap" LineHeight="16" Visibility="Visible"/>
                </StackPanel>

                <!--Trailer Section (if available)-->
                <StackPanel x:Name="TrailerSection" Margin="0,0,0,20">
                    <TextBlock Text="{DynamicResource AnimePage.Trailer}" FontSize="14" FontWeight="Bold" 
                               Foreground="#333333" Margin="0,0,0,8"/>
                    <Button Content="{DynamicResource AnimePage.WatchTrailer}"
                            Width="220"
                            Padding="10,8"
                            Background="#FF9800"
                            Foreground="White"
                            BorderBrush="Transparent"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Click="OpenTrailerButton_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>