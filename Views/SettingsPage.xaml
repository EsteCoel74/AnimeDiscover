<UserControl x:Class="AnimeDiscover.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="500" d:DesignWidth="900">
    <!-- Page paramètres : personnalisation du thème -->
    <Grid>
        <Grid.Background>
            <DynamicResource ResourceKey="MainGradientBrush"/>
        </Grid.Background>

        <Border Margin="22"
                Padding="18"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="SettingsToggleButtonStyle" TargetType="ToggleButton">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryColor}"/>
                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ToggleRoot"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="10,6"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ToggleRoot" Property="Background" Value="{DynamicResource InfoBrush}"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleRoot" Property="BorderBrush" Value="{DynamicResource InfoBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{DynamicResource Settings.Title}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryColor}"
                           Margin="0,0,0,14"/>

                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource Settings.Language}" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold"/>
                    <ComboBox x:Name="LanguageComboBox"
                              MinHeight="36"
                              Margin="0,0,0,12"
                              Background="{DynamicResource SurfaceAltBrush}"
                              BorderBrush="{DynamicResource BorderBrushSoft}"
                              Foreground="Black"
                              TextElement.Foreground="Black"
                              FontWeight="SemiBold"
                              ItemContainerStyle="{StaticResource SettingsComboBoxItemStyle}"
                              ToolTip="{DynamicResource Settings.LanguageToolTip}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Foreground="Black"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource Settings.Theme}" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="LightThemeToggleButton"
                                      Content="{DynamicResource Settings.ThemeLight}"
                                      Style="{StaticResource SettingsToggleButtonStyle}"
                                      MinWidth="110"
                                      MinHeight="36"
                                      Margin="0,0,8,0"
                                      Click="LightThemeToggleButton_Click"
                                      ToolTip="{DynamicResource Settings.ThemeLightTip}"/>
                        <ToggleButton x:Name="DarkThemeToggleButton"
                                      Content="{DynamicResource Settings.ThemeDark}"
                                      Style="{StaticResource SettingsToggleButtonStyle}"
                                      MinWidth="110"
                                      MinHeight="36"
                                      Click="DarkThemeToggleButton_Click"
                                      ToolTip="{DynamicResource Settings.ThemeDarkTip}"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource Settings.Animations}" Margin="0,12,0,6" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="AnimationsOnToggleButton"
                                      Content="{DynamicResource Settings.AnimationsOn}"
                                      Style="{StaticResource SettingsToggleButtonStyle}"
                                      MinWidth="110"
                                      MinHeight="36"
                                      Margin="0,0,8,0"
                                      ToolTip="{DynamicResource Settings.AnimationsOnTip}"/>
                        <ToggleButton x:Name="AnimationsOffToggleButton"
                                      Content="{DynamicResource Settings.AnimationsOff}"
                                      Style="{StaticResource SettingsToggleButtonStyle}"
                                      MinWidth="130"
                                      MinHeight="36"
                                      ToolTip="{DynamicResource Settings.AnimationsOffTip}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="{DynamicResource Settings.Cancel}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click"
                            Style="{StaticResource HeaderSubtleButtonStyle}"/>
                    <Button Content="{DynamicResource Settings.Save}"
                            MinWidth="120"
                            Click="SaveButton_Click"
                            Style="{StaticResource SuccessButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
