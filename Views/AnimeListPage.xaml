<UserControl x:Class="AnimeDiscover.Views.AnimeListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnimeDiscover.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Header with Back Button-->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,0,10">
            <Button Content="← Retour" Padding="10,8" Background="#2196F3" Foreground="White" 
                    Cursor="Hand" x:Name="BackButton" Click="BackButton_Click"/>
            <TextBlock Text="Ma Liste d'Animes" FontSize="20" FontWeight="Bold" 
                       Foreground="#333333" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <!--Anime List Grid-->
        <DataGrid Grid.Row="1" x:Name="AnimeListGrid"
                  ItemsSource="{Binding UserAnimes}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Background="White"
                  Margin="20">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Image" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" Height="100"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Titre" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>

                <DataGridTemplateColumn Header="Vu" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsWatched, UpdateSourceTrigger=PropertyChanged}" 
                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Note (0-10)" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Slider Minimum="0" Maximum="10" Value="{Binding UserScore, UpdateSourceTrigger=PropertyChanged}" 
                                    VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Score MAL" Binding="{Binding Score, StringFormat='0.0'}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
