<Window x:Class="AnimeDiscover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnimeDiscover"
        mc:Ignorable="d"
        Title="AnimeDiscover" Height="650" Width="1000">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#140E3D" Offset="0.0"/>
                <GradientStop Color="#8378C7" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!--========== Top Header Row ==========-->
        <Grid Grid.Row="0" Background="#1A1A2E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <!--Logo and Title-->
            <Border Grid.Column="0" Margin="10,5,20,5" Background="Transparent" CornerRadius="5" Padding="5">
                <Image Source="Assets/logo.png" 
                       VerticalAlignment="Center" HorizontalAlignment="Left" 
                       Stretch="Uniform" MaxHeight="55"/>
            </Border>

            <!--Settings Button-->
            <Button Grid.Column="1" Content="⚙ Paramètres" HorizontalAlignment="Right" VerticalAlignment="Center" 
                    Margin="0,0,15,0" Padding="12,8" Background="#5F6062" 
                    BorderBrush="#999999" BorderThickness="1" Cursor="Hand" Foreground="White" FontWeight="Bold"/>
        </Grid>

        <!--========== Search and Filter Row ==========-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!--Search Bar with Suggestions-->
            <Grid Grid.Column="0" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="SearchTextBox" 
                             Padding="12,10" 
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             BorderBrush="#4CAF50" 
                             BorderThickness="2"
                             Background="#F5F5F5"/>

                    <Button Grid.Column="1" Content="🔍" Margin="5,0,0,0" 
                            Background="#4CAF50" Foreground="White" 
                            FontSize="18" Cursor="Hand" x:Name="SearchButton"/>
                </Grid>

                <!--Search Suggestions Dropdown-->
                <ListBox Grid.Row="1" x:Name="SuggestionsListBox" 
                         Visibility="Collapsed"
                         MaxHeight="150"
                         Background="White"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         Margin="0,2,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Padding="10,5" Foreground="#333333"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!--Genre Filter-->
            <ComboBox Grid.Column="2" x:Name="GenreComboBox" 
                      Padding="10,10"
                      FontSize="12"
                      VerticalContentAlignment="Center"
                      BorderBrush="#CCCCCC" 
                      BorderThickness="1"
                      Background="White">
                <ComboBoxItem IsSelected="True">Tous les genres</ComboBoxItem>
                <ComboBoxItem>Action</ComboBoxItem>
                <ComboBoxItem>Aventure</ComboBoxItem>
                <ComboBoxItem>Comédie</ComboBoxItem>
                <ComboBoxItem>Drame</ComboBoxItem>
                <ComboBoxItem>Fantasy</ComboBoxItem>
                <ComboBoxItem>Horror</ComboBoxItem>
                <ComboBoxItem>Romance</ComboBoxItem>
                <ComboBoxItem>Sci-Fi</ComboBoxItem>
                <ComboBoxItem>Slice of Life</ComboBoxItem>
                <ComboBoxItem>Sports</ComboBoxItem>
                <ComboBoxItem>Surnaturel</ComboBoxItem>
            </ComboBox>

            <!--Type Filter-->
            <ComboBox Grid.Column="4" x:Name="TypeComboBox" 
                      Padding="10,10"
                      FontSize="12"
                      VerticalContentAlignment="Center"
                      BorderBrush="#CCCCCC" 
                      BorderThickness="1"
                      Background="White">
                <ComboBoxItem IsSelected="True">Tous les types</ComboBoxItem>
                <ComboBoxItem>TV</ComboBoxItem>
                <ComboBoxItem>Movie</ComboBoxItem>
                <ComboBoxItem>OVA</ComboBoxItem>
                <ComboBoxItem>ONA</ComboBoxItem>
                <ComboBoxItem>Special</ComboBoxItem>
            </ComboBox>

            <!--My List Button-->
            <Button Grid.Column="6" Content="📋 Ma Liste" 
                    Background="#2196F3" Foreground="White" 
                    FontSize="12" Cursor="Hand" Padding="10,10" Margin="0,0,10,0" FontWeight="Bold" x:Name="MyListButton"/>
        </Grid>

        <!--========== Content Area ==========-->
        <ContentControl Grid.Row="2" x:Name="ContentArea" Background="#FAFAFA"/>

        <!--========== Footer ==========-->
        <Border Grid.Row="3" Background="#1A1A2E" BorderBrush="#404040" BorderThickness="0,1,0,0">
            <TextBlock Text="© 2024 AnimeDiscover - Powered by Jikan API" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       FontSize="12" Foreground="#CCCCCC"/>
        </Border>
    </Grid>
</Window>
