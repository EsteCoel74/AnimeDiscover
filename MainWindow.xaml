<Window x:Class="AnimeDiscover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnimeDiscover"
        mc:Ignorable="d"
        Title="AnimeDiscover" Height="650" Width="1000"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.Background>
            <DynamicResource ResourceKey="MainGradientBrush"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="78"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!--========== Top Header Row ==========-->
        <Grid Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <!--Logo and Title-->
            <Border Grid.Column="0" Margin="10,5,20,5" Background="Transparent" CornerRadius="5" Padding="5">
                <Image Source="Assets/logo.png" 
                       VerticalAlignment="Center" HorizontalAlignment="Left" 
                       Stretch="Uniform" MaxHeight="55"/>
            </Border>

            <!--Settings Button-->
            <Button Grid.Column="1" Content="⚙ Paramètres" HorizontalAlignment="Right" VerticalAlignment="Center" 
                    Margin="0,0,15,0" Style="{StaticResource PrimaryButtonStyle}"/>
        </Grid>

        <!--========== Search and Filter Row ==========-->
        <Border Grid.Row="1" Margin="12,8,12,8" Padding="10,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="145"/>
                </Grid.ColumnDefinitions>

            <!--Search Bar with Suggestions-->
            <Grid Grid.Column="0" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="SearchTextBox"
                             VerticalContentAlignment="Center"
                             MinHeight="36"
                             ToolTip="Saisis un titre, un genre ou un critère puis appuie sur Entrée"/>

                    <Button Grid.Column="1" Content="🔍" Margin="5,0,0,0" 
                            FontSize="16" MinHeight="36" x:Name="SearchButton" Style="{StaticResource SuccessButtonStyle}"/>
                </Grid>

                <!--Search Suggestions Dropdown-->
                <ListBox Grid.Row="1" x:Name="SuggestionsListBox" 
                         Visibility="Collapsed"
                         MaxHeight="150"
                         Margin="0,2,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Padding="10,6" Foreground="{DynamicResource TextPrimaryColor}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!--Genre Filter-->
            <ComboBox Grid.Column="2" x:Name="GenreComboBox" VerticalContentAlignment="Center" MinHeight="36">
                <ComboBoxItem IsSelected="True">Tous les genres</ComboBoxItem>
                <ComboBoxItem>Action</ComboBoxItem>
                <ComboBoxItem>Aventure</ComboBoxItem>
                <ComboBoxItem>Comédie</ComboBoxItem>
                <ComboBoxItem>Drame</ComboBoxItem>
                <ComboBoxItem>Fantasy</ComboBoxItem>
                <ComboBoxItem>Horror</ComboBoxItem>
                <ComboBoxItem>Romance</ComboBoxItem>
                <ComboBoxItem>Sci-Fi</ComboBoxItem>
                <ComboBoxItem>Slice of Life</ComboBoxItem>
                <ComboBoxItem>Sports</ComboBoxItem>
                <ComboBoxItem>Surnaturel</ComboBoxItem>
            </ComboBox>

            <!--Type Filter-->
            <ComboBox Grid.Column="4" x:Name="TypeComboBox" VerticalContentAlignment="Center" MinHeight="36">
                <ComboBoxItem IsSelected="True">Tous les types</ComboBoxItem>
                <ComboBoxItem>TV</ComboBoxItem>
                <ComboBoxItem>Movie</ComboBoxItem>
                <ComboBoxItem>OVA</ComboBoxItem>
                <ComboBoxItem>ONA</ComboBoxItem>
                <ComboBoxItem>Special</ComboBoxItem>
            </ComboBox>

            <!--My List Button-->
            <Button Grid.Column="6" Content="📋 Ma Liste" 
                    MinHeight="36" x:Name="MyListButton" Style="{StaticResource InfoButtonStyle}"/>

            <!--AI Assistant Button-->
            <Button Grid.Column="8" Content="🤖 IA Anime"
                    MinHeight="36" x:Name="AiAssistantButton" Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>

        <!--========== Content Area ==========-->
        <ContentControl Grid.Row="2" x:Name="ContentArea" Background="#FAFAFA"/>

        <!--========== Footer ==========-->
        <Border Grid.Row="3" Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="#404040" BorderThickness="0,1,0,0">
            <TextBlock Text="© 2024 AnimeDiscover - Powered by Jikan API" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       FontSize="12" Foreground="#CCCCCC"/>
        </Border>
    </Grid>
</Window>
